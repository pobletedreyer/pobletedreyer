---
// Base layout for all pages. Receives locale and meta overrides.
import "../styles/global.css";
import Analytics from '@vercel/analytics/astro';
import { defaultLocale, htmlLangMap, type Locale } from "../i18n/config";
import { t, switchLocalePath } from "../i18n/utils";

interface Props {
  locale?: Locale;
  title?: string;
  description?: string;
  image?: string;
}

const {
  locale = defaultLocale,
  title,
  description,
  image = "/photos/vicuna_rainbow.jpg",
} = Astro.props as Props;

const resolvedTitle = title ?? t("meta.default_title", locale);
const resolvedDescription = description ?? t("meta.default_description", locale);
const ogLocale = locale === "es" ? "es_CL" : "en_US";
const htmlLang = htmlLangMap[locale];

// Build absolute URLs for OG tags
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);

// hreflang alternates — the equivalent URL in the other language
const currentPath = Astro.url.pathname;
const altEnURL = new URL(switchLocalePath(currentPath, "en"), Astro.site);
const altEsURL = new URL(switchLocalePath(currentPath, "es"), Astro.site);
---

<!DOCTYPE html>
<html lang={htmlLang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <!-- First-visit language detection. Runs ASAP to minimize flash.
       Skips if user already has a cookie, only redirects EN→ES (never the reverse). -->
  <script is:inline>
    (function () {
      try {
        var hasCookie = /(?:^|;\s*)pd_lang=/.test(document.cookie);
        if (hasCookie) return;
        var lang = (navigator.language || 'en').toLowerCase();
        var prefersEs = lang.indexOf('es') === 0;
        var path = window.location.pathname;
        var isEs = path === '/es' || path.indexOf('/es/') === 0;
        // Persist the inferred preference so we don't re-evaluate on every page
        var inferred = prefersEs ? 'es' : 'en';
        document.cookie = 'pd_lang=' + inferred + ';path=/;max-age=31536000;samesite=lax';
        if (prefersEs && !isEs) {
          var newPath = '/es' + (path === '/' ? '/' : path);
          window.location.replace(newPath + window.location.search + window.location.hash);
        }
      } catch (e) { /* ignore */ }
    })();
  </script>

  <!-- Primary Meta Tags -->
  <title>{resolvedTitle}</title>
  <meta name="title" content={resolvedTitle} />
  <meta name="description" content={resolvedDescription} />
  <meta name="author" content="Lucas Poblete Dreyer" />
  <meta name="keywords" content="Lucas Poblete Dreyer, Atacama photography, wildlife photography, Chile, vicuña, flamingo, altiplano, San Pedro de Atacama, fine art photography" />

  <!-- Canonical + hreflang -->
  <link rel="canonical" href={canonicalURL} />
  <link rel="alternate" hreflang="en" href={altEnURL} />
  <link rel="alternate" hreflang="es" href={altEsURL} />
  <link rel="alternate" hreflang="x-default" href={altEnURL} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={resolvedTitle} />
  <meta property="og:description" content={resolvedDescription} />
  <meta property="og:image" content={imageURL} />
  <meta property="og:image:width" content="1600" />
  <meta property="og:image:height" content="1067" />
  <meta property="og:site_name" content="Lucas Poblete Dreyer" />
  <meta property="og:locale" content={ogLocale} />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={canonicalURL} />
  <meta property="twitter:title" content={resolvedTitle} />
  <meta property="twitter:description" content={resolvedDescription} />
  <meta property="twitter:image" content={imageURL} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,200;0,9..144,300;0,9..144,400;0,9..144,500;1,9..144,300;1,9..144,400&family=Inter+Tight:wght@300;400;500&display=swap"
    rel="stylesheet"
  />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body oncontextmenu="return false;">
  <slot />
  <Analytics />
</body>
</html>
