---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";

// Get all photos and sort by 'order' field
const allPhotos = await getCollection("photos");
const photos = allPhotos.sort((a, b) => a.data.order - b.data.order);

// Separate diptych photos (last two) from sequence photos
const sequencePhotos = photos.filter(
  (p) => p.data.layout !== "diptych-left" && p.data.layout !== "diptych-right"
);
const diptychLeft = photos.find((p) => p.data.layout === "diptych-left");
const diptychRight = photos.find((p) => p.data.layout === "diptych-right");
---

<BaseLayout
  title="The Living Desert · Lucas Poblete Dreyer"
  description="A continuing record of the Atacama Desert — flamingos, vicuñas, viscachas, and the life that thrives in what looks, at first, like absence."
>
  <Nav active="work" />

  <div class="series-page">
    <div class="series-intro">
      <div class="breadcrumb"><a href="/">Work</a> &nbsp;/&nbsp; The Living Desert</div>
      <h1>The Living Desert</h1>
      <div class="meta-row">
        <span>Atacama, Chile</span>·<span>2025 — Ongoing</span>·<span>{photos.length} photographs shown</span>
      </div>
      <p>The Atacama appears, at first, as absence — a vast and silent geometry of salt, stone, and sky. But return to it, and the desert reveals its inhabitants. A flamingo bent over brine. A viscacha among red stones. A vicuña, attentive and elsewhere.</p>
      <p>This series is a continuing record of those encounters.</p>
      <p class="byline">— Photographs by Lucas Poblete Dreyer</p>
    </div>

    <div class="sequence">
      {sequencePhotos.map((photo) => (
        <>
          <div class={`plate ${photo.data.layout}`}>
            <img src={photo.data.image} alt={photo.data.alt} />
            <div class="caption">
              <span class="num">{String(photo.data.order).padStart(2, "0")}</span>
              {photo.data.caption}
            </div>
          </div>
          {photo.data.interlude_after && (
            <div class="text-interlude">{photo.data.interlude_after}</div>
          )}
        </>
      ))}

      {/* CIERRE: Díptico arcoíris */}
      {diptychLeft && diptychRight && (
        <div class="plate diptych">
          <div class="panel">
            <img src={diptychLeft.data.image} alt={diptychLeft.data.alt} />
            <div class="caption">
              <span class="num">{String(diptychLeft.data.order).padStart(2, "0")}</span>
              {diptychLeft.data.caption}
            </div>
          </div>
          <div class="panel">
            <img src={diptychRight.data.image} alt={diptychRight.data.alt} />
            <div class="caption">
              <span class="num">{String(diptychRight.data.order).padStart(2, "0")}</span>
              {diptychRight.data.caption}
            </div>
          </div>
        </div>
      )}
    </div>
  </div>

  <Footer />
</BaseLayout>
