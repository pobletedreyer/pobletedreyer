---
// Footer component — used on all pages, receives locale.
import { useTranslations } from "../i18n/utils";
import type { Locale } from "../i18n/config";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props as Props;
const t = useTranslations(locale);
const currentYear = new Date().getFullYear();
---

<footer>
  <div class="footer-grid">
    <div>
      <h4>{t("footer.studio")}</h4>
      <p>Lucas Poblete Dreyer</p>
      <p>{t("footer.studio_location")}</p>
    </div>
    <div>
      <h4>{t("footer.contact")}</h4>
      <a href="mailto:hola@pobletedreyer.com">hola@pobletedreyer.com</a>
      <a href="https://instagram.com/pobletedreyer" target="_blank" rel="noopener">@pobletedreyer</a>
    </div>
    <div>
      <h4>{t("footer.prints")}</h4>
      <p>{t("footer.prints_blurb")}</p>
      <a href="mailto:hola@pobletedreyer.com?subject=Print%20inquiry">{t("footer.inquire")}</a>
    </div>
  </div>
  <div class="copyright">
    © {currentYear} Lucas Poblete Dreyer · {t("footer.copyright")}
  </div>
</footer>
